# Model — Ollama model tag (pulled automatically on first run)
# BF16 full precision: qwen3.6:27b-bf16  (~54 GB VRAM — needs A100 80GB)
# Smaller options:     qwen3.6:27b-q4_K_M (~16 GB VRAM — RTX 3090/4090)
#                      qwen3:8b-bf16       (~ 16 GB VRAM)
MODEL_ID=qwen3.6:27b-bf16

# Service Ports
OLLAMA_PORT=11434
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Generation Defaults
MAX_TOKENS=4096
TEMPERATURE=0.7

# Ollama Parallelism (concurrent requests)
OLLAMA_NUM_PARALLEL=2
