# HuggingFace token — required to download Qwen/Qwen3.6-27B
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Model — HuggingFace model ID
# RTX Pro 6000 96GB (BF16 full precision, ~54 GB VRAM, 42 GB KV cache headroom)
MODEL_ID=Qwen/Qwen3.6-27B

# Context length — 262144 is native max; safe on 96GB (32+ GB KV headroom after weights)
MAX_MODEL_LEN=262144

# GPU memory fraction vLLM reserves (0.90 leaves headroom for CUDA kernels)
GPU_MEM_UTIL=0.90

# Service Ports
VLLM_PORT=8000
BACKEND_PORT=8080
FRONTEND_PORT=3000
WHISPER_PORT=9000

# Generation Defaults
MAX_TOKENS=4096
TEMPERATURE=0.7
