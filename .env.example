# ── Model ─────────────────────────────────────────────────────────────────────
# HuggingFace token — required to download Qwen/Qwen3.6-27B (first run only)
HF_TOKEN=hf_your_token_here

# HuggingFace model ID
# RTX Pro 6000 96GB → BF16 full precision (~54 GB VRAM, 42 GB KV headroom)
MODEL_ID=Qwen/Qwen3.6-27B

# ── vLLM ──────────────────────────────────────────────────────────────────────
# Max context length — 262144 is native max; safe on 96GB
MAX_MODEL_LEN=262144

# GPU memory fraction vLLM reserves (0.90 leaves headroom for CUDA kernels)
GPU_MEM_UTIL=0.90

# Encoder embedding cache size (tokens) used by chunk_dispatch.assert_chunks_fit_budget
# to catch oversize chunks at plan time. MUST match or be <= vLLM's
# --max-num-batched-tokens (and, if the flag is present in your vLLM build,
# --max-num-encoder-input-tokens). Client asserts against 0.85 x this value.
VLLM_ENCODER_CACHE=32768

# Vision processor settings — passed per-request via extra_body.mm_processor_kwargs,
# overriding the vLLM server default in docker-compose.yml --mm-processor-kwargs.
# analyze_context.py reads these at startup to keep the budget assert accurate.
#
# VLLM_MM_FPS — frames sampled per second from each video chunk.
#   0.5 (default) → halves visual tokens vs 1.0 → ~2x faster prefill, sufficient quality
#   1.0           → full frame rate, higher accuracy on fast-cut content
#   Must stay consistent with docker-compose.yml --mm-processor-kwargs fps
#   if you do NOT want per-request override (they override independently).
#
# VLLM_MM_MAX_PIXELS — max pixel area per frame. Controls resolution tokens/frame.
#   602112 = ~776×776 effective → 3072 tokens/frame at full resolution
#   200704 = ~448×448           → ~1024 tokens/frame (6x cheaper, lower detail)
VLLM_MM_FPS=0.5
VLLM_MM_MAX_PIXELS=602112

# ── Service Ports ─────────────────────────────────────────────────────────────
VLLM_PORT=8000
BACKEND_PORT=8080
FRONTEND_PORT=3000
WHISPER_PORT=9000

# ── Generation Defaults ───────────────────────────────────────────────────────
MAX_TOKENS=4096
TEMPERATURE=0.7

# ── Pinecone (vector search) ──────────────────────────────────────────────────
# Create index at: https://app.pinecone.io
# Use model: llama-text-embed-v2  |  Dimensions: 1024  |  Metric: cosine
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_HOST=emeding1-z5tx6hc.svc.aped-4627-b74a.pinecone.io
PINECONE_INDEX=emeding1

# ── Neo4j (knowledge graph) ───────────────────────────────────────────────────
# Runs locally via: make neo4j-up  |  Browser: http://localhost:7474
# Change NEO4J_PASSWORD here AND in docker-compose.yml NEO4J_AUTH env var
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=katai_neo4j_2026
